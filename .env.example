# =============================================================================
# Safar CRM — environment variables
# Every variable is parsed and validated by lib/env.ts (Zod).
# The app refuses to boot if any required variable is missing/invalid.
# =============================================================================

# --- Database (Neon) -----------------------------------------------------
# Pooled URL — append ?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connection_limit=1"
# Direct (non-pooled) URL for migrations and admin scripts
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Better Auth ---------------------------------------------------------
# 32+ random bytes; generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
# Client-side base URL for the Better Auth browser client (lib/auth/client.ts).
# Set to the same public origin as BETTER_AUTH_URL in each environment.
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# --- Sentry --------------------------------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# --- Cloudflare R2 -------------------------------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_DOCUMENTS="safar-crm-dev-docs"
R2_PUBLIC_HOST=""

# --- Email (Resend) ------------------------------------------------------
RESEND_API_KEY=""
EMAIL_FROM="noreply@safarcrm.local"

# --- Cron ----------------------------------------------------------------
# Random secret required in `Authorization` header on every /api/cron/* call
CRON_SECRET=""

# --- Logging -------------------------------------------------------------
LOG_LEVEL="info"

# --- Runtime -------------------------------------------------------------
NODE_ENV="development"

# --- Seed (Phase 0) ------------------------------------------------------
SEED_ADMIN_EMAIL="admin@safarcrm.local"
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="Admin"
